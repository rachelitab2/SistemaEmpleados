@page "/calculadora"

<h2>🧮 Calculadora de Nómina TSS 2026</h2>
<p style="color:gray">Escribe el salario — los resultados aparecen solos.</p>

<div style="max-width:420px">
	<label><strong>Salario bruto (RD$)</strong></label>

	<input type="number"
		   @bind="salario"
		   @bind:event="oninput"
		   placeholder="Ej: 35000"
		   style="width:100%; padding:8px; margin:8px 0; font-size:1rem" />


	@if (salario > 0)
	{
		<p>✅ AFP: @afp.ToString("N2")</p>
		<p>✅ SFS: @sfs.ToString("N2")</p>
		<p>✅ Neto: @neto.ToString("N2")</p>
	}
</div>

@code {
	private decimal salario = 0;

	private decimal afp => salario * 0.0287m;
	private decimal sfs => salario * 0.0304m;
	private decimal neto => salario - afp - sfs;

}